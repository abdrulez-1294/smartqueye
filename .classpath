<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<!-- Java source folder -->
	<classpathentry kind="src" path="src"/>

	<!-- JRE System Library — Java 17 -->
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-17"/>

	<!--
	    Apache Tomcat 10.1 Runtime — provides jakarta.servlet.* API.

	    IMPORTANT: If Eclipse shows a build error "Unbound classpath container",
	    do ONE of the following:

	    Option A (Recommended): Right-click project → Build Path → Configure
	      Build Path → Libraries tab → find the red "Tomcat" entry →
	      click Edit → choose your installed Tomcat 10.1 → OK.

	    Option B: In Eclipse Servers view, make sure Tomcat is named exactly:
	      "Apache Tomcat v10.1"
	      (Window → Preferences → Server → Runtime Environments → rename it)

	    Option C (Quick fix): Delete this entry from .classpath, then:
	      Right-click project → Build Path → Add Library →
	      Server Runtime → Apache Tomcat v10.1
	-->
	<classpathentry kind="con" path="org.eclipse.jst.server.core.container/org.eclipse.jst.server.tomcat.runtimeTarget/Apache Tomcat v10.1"/>

	<!-- Web App Libraries: auto-picks all JARs from WebContent/WEB-INF/lib/ -->
	<classpathentry kind="con" path="org.eclipse.jst.j2ee.internal.web.container"/>

	<!-- Build output directory -->
	<classpathentry kind="output" path="build/classes"/>
</classpath>
